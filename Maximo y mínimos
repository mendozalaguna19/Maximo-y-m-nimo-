<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculadora de Máximos y Mínimos de Inventario</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f6f9;
            color: #333;
            margin: 0;
            padding: 20px;
        }
        .container {
            max-width: 600px;
            background: #fff;
            margin: 20px auto;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        h2 {
            text-align: center;
            color: #2c3e50;
            margin-bottom: 25px;
        }
        .form-group {
            margin-bottom: 15px;
        }
        label {
            display: block;
            margin-bottom: 5px;
            font-weight: 600;
        }
        input, select {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 4px;
            box-sizing: border-box;
            font-size: 14px;
        }
        button {
            width: 100%;
            padding: 12px;
            background-color: #3498db;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 16px;
            cursor: pointer;
            font-weight: bold;
            margin-top: 15px;
        }
        button:hover {
            background-color: #2980b9;
        }
        .results {
            margin-top: 25px;
            padding: 20px;
            background-color: #ecf0f1;
            border-radius: 6px;
            display: none;
        }
        .results h3 {
            margin-top: 0;
            color: #2c3e50;
            border-bottom: 2px solid #bdc3c7;
            padding-bottom: 5px;
        }
        .result-item {
            display: flex;
            justify-content: space-between;
            margin: 10px 0;
            font-size: 16px;
        }
        .result-item span {
            font-weight: bold;
            color: #2c3e50;
        }
    </style>
</head>
<body>

<div class="container">
    <h2>Control de Máximos y Mínimos</h2>
    
    <div class="form-group">
        <label for="periodo">Tipo de Demanda:</label>
        <select id="periodo" onchange="actualizarLabels()">
            <option value="mes">Mensual</option>
            <option value="semana">Semanal</option>
        </select>
    </div>

    <div class="form-group">
        <label id="lbl-demanda" for="demanda">Demanda Promedio Mensual:</label>
        <input type="number" id="demanda" placeholder="Ej. 500" min="0">
    </div>

    <div class="form-group">
        <label id="lbl-entrega" for="entrega">Tiempo de Entrega del Proveedor (en meses):</label>
        <input type="number" id="entrega" step="0.1" placeholder="Ej. 0.5 (medio mes)" min="0">
    </div>

    <div class="form-group">
        <label for="seguridad">Inventario de Seguridad (Unidades):</label>
        <input type="number" id="seguridad" placeholder="Ej. 50" min="0">
    </div>

    <div class="form-group">
        <label for="lote">Cantidad Estándar de Pedido (Lote Óptimo):</label>
        <input type="number" id="lote" placeholder="Ej. 300" min="0">
    </div>

    <button onclick="calcularInventario()">Calcular Niveles</button>

    <div class="results" id="resultados">
        <h3>Resultados del Análisis</h3>
        <div class="result-item">Inventario Mínimo (Seguridad): <span id="res-min">0</span></div>
        <div class="result-item">Punto de Reorden (Hacer pedido): <span id="res-reorden">0</span></div>
        <div class="result-item">Inventario Máximo Sugerido: <span id="res-max">0</span></div>
    </div>
</div>

<script>
function actualizarLabels() {
    const periodo = document.getElementById('periodo').value;
    const lblDemanda = document.getElementById('lbl-demanda');
    const lblEntrega = document.getElementById('lbl-entrega');

    if (periodo === 'mes') {
        lblDemanda.innerText = "Demanda Promedio Mensual:";
        lblEntrega.innerText = "Tiempo de Entrega del Proveedor (en meses):";
        document.getElementById('entrega').placeholder = "Ej. 0.5 (medio mes)";
    } else {
        lblDemanda.innerText = "Demanda Promedio Semanal:";
        lblEntrega.innerText = "Tiempo de Entrega del Proveedor (en semanas):";
        document.getElementById('entrega').placeholder = "Ej. 2 (dos semanas)";
    }
}

function calcularInventario() {
    // Obtener valores de los inputs
    const demanda = parseFloat(document.getElementById('demanda').value) || 0;
    const entrega = parseFloat(document.getElementById('entrega').value) || 0;
    const seguridad = parseFloat(document.getElementById('seguridad').value) || 0;
    const lote = parseFloat(document.getElementById('lote').value) || 0;

    if (demanda <= 0 || entrega <= 0) {
        alert("Por favor, ingresa valores válidos para la demanda y el tiempo de entrega.");
        return;
    }

    // Cálculos
    const puntoReorden = Math.ceil((demanda * entrega) + seguridad);
    const inventarioMinimo = seguridad; 
    const inventarioMaximo = Math.ceil(puntoReorden + lote);

    // Mostrar resultados
    document.getElementById('res-min').innerText = inventarioMinimo + " unidades";
    document.getElementById('res-reorden').innerText = puntoReorden + " unidades";
    document.getElementById('res-max').innerText = inventarioMaximo + " unidades";
    
    document.getElementById('resultados').style.display = 'block';
}
</script>

</body>
</html>
